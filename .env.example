diff --git a/.env.example b/.env.example
new file mode 100644
index 0000000000000000000000000000000000000000..cdced86a625b40dd5794db2fe558f5a2ac9654dd
--- /dev/null
+++ b/.env.example
@@ -0,0 +1,12 @@
+# HTTP port for local/dev/prod run
+PORT=3000
+
+# Password for admin endpoints (/admin, /api/orders, /api/commerceml/upload-zip)
+ADMIN_PASSWORD=070738
+
+# Image optimization settings for /img proxy
+IMAGE_WIDTH=220
+IMAGE_QUALITY=42
+
+# Cache freshness window (ms) used in /api/health and image cache invalidation logic
+CACHE_TTL_MS=21600000
